<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#0F0F14">

    <!-- MODERN SIDE NAVIGATION MENU -->
    <LinearLayout
        android:layout_width="240dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#16161F"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MyIPTV Hub"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📺 Live TV"
            android:textColor="#388E3C"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎬 Movies (TMDB)"
            android:textColor="#AAAAAA"
            android:textSize="18sp"
            android:padding="12dp"
            android:focusable="true"
            android:layout_marginTop="8dp"
            android:background="?android:attr/selectableItemBackground"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ Settings"
            android:textColor="#AAAAAA"
            android:textSize="18sp"
            android:padding="12dp"
            android:focusable="true"
            android:layout_marginTop="8dp"
            android:background="?android:attr/selectableItemBackground"/>
    </LinearLayout>

    <!-- RIGHT CONTENT AREA (POSTERS + VIDEO) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/menuTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trending Content"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="12dp" />

        <!-- TMDB Horizontal Row -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/posterRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:orientation="horizontal" />

        <!-- Video Player Frame underneath -->
        <VideoView
            android:id="@+id/mainVideoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp" />
    </LinearLayout>

</LinearLayout>
