<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph"
        app:layout_constraintStart_toEndOf="@id/sidebarContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <View
        android:id="@+id/sidebarOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:alpha="0"
        android:visibility="gone"
        android:clickable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:id="@+id/sidebarContainer"
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#CC0A0E1A"
        android:elevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="72dp">
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher"
                android:scaleType="fitCenter"/>
            <TextView
                android:id="@+id/sidebarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="56dp"
                android:text="MyIPTV Hub"
                android:textColor="#48CAE4"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"/>
        </FrameLayout>

        <View android:focusable="false" android:layout_width="36dp" android:layout_height="1dp"
            android:layout_gravity="center_horizontal"
            android:background="#2248CAE4" android:layout_marginBottom="8dp"/>

        <LinearLayout android:id="@+id/navHome"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="18dp" android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView android:id="@+id/navHomeIcon"
                android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_home" android:tint="#48CAE4"/>
            <TextView android:id="@+id/navHomeLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textColor="#FFFFFF" android:textSize="15sp"
                android:paddingStart="16dp" android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navMovies"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="18dp" android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView android:id="@+id/navMoviesIcon"
                android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_movies" android:tint="#607D8B"/>
            <TextView android:id="@+id/navMoviesLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Movies" android:textColor="#B0BEC5" android:textSize="15sp"
                android:paddingStart="16dp" android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navTvShows"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="18dp" android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView android:id="@+id/navTvShowsIcon"
                android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_tv_shows" android:tint="#607D8B"/>
            <TextView android:id="@+id/navTvShowsLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TV Shows" android:textColor="#B0BEC5" android:textSize="15sp"
                android:paddingStart="16dp" android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navLiveTv"
            android:nextFocusDown="@+id/navSettings"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="18dp" android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView android:id="@+id/navLiveTvIcon"
                android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_live_tv" android:tint="#607D8B"/>
            <TextView android:id="@+id/navLiveTvLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Live TV" android:textColor="#B0BEC5" android:textSize="15sp"
                android:paddingStart="16dp" android:visibility="gone"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:focusable="false"/>

        <View android:focusable="false" android:layout_width="36dp" android:layout_height="1dp"
            android:layout_gravity="center_horizontal"
            android:background="#2248CAE4" android:layout_marginBottom="8dp"/>

        <LinearLayout android:id="@+id/navSettings"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="18dp" android:focusable="true"
            android:layout_marginBottom="8dp"
            android:background="?attr/selectableItemBackground">
            <ImageView android:id="@+id/navSettingsIcon"
                android:layout_width="30dp" android:layout_height="30dp"
                android:src="@drawable/ic_settings" android:tint="#607D8B"/>
            <TextView android:id="@+id/navSettingsLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Settings" android:textColor="#B0BEC5" android:textSize="15sp"
                android:paddingStart="16dp" android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
