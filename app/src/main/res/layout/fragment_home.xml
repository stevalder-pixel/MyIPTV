<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <!-- Full screen backdrop hero always visible -->
    <ImageView android:id="@+id/heroBackdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>

    <View android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/hero_gradient"/>

    <!-- Hero info top left -->
    <LinearLayout
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start|center_vertical"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView android:id="@+id/heroTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:fontFamily="@font/netflix_sans_medium"/>

        <LinearLayout android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <TextView android:id="@+id/heroRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/pill_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="#48CAE4"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView android:id="@+id/heroYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B0BEC5"
                android:textSize="13sp"
                android:paddingStart="10dp"/>
        </LinearLayout>

        <TextView android:id="@+id/heroOverview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#B0BEC5"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"/>

        <LinearLayout android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">
            <Button android:id="@+id/heroPlayBtn"
                android:layout_width="140dp"
                android:layout_height="48dp"
                android:text="▶  Play"
                android:backgroundTint="#48CAE4"
                android:textColor="#0A0E1A"
                android:textStyle="bold"
                android:textSize="15sp"
                android:fontFamily="@font/netflix_sans_medium"
                android:layout_marginEnd="12dp"/>
            <Button android:id="@+id/heroInfoBtn"
                android:layout_width="140dp"
                android:layout_height="48dp"
                android:text="ⓘ  More Info"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Row section bottom - ONE row visible at a time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#CC0A0E1A"
        android:paddingBottom="8dp">

        <!-- Row label -->
        <TextView android:id="@+id/rowLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trending Movies"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/netflix_sans_medium"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"/>

        <!-- Watchlist row -->
        <LinearLayout android:id="@+id/watchlistSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Watchlist"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/netflix_sans_medium"
                android:paddingStart="16dp"
                android:paddingBottom="8dp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/watchlistRow"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:paddingHorizontal="12dp"
                android:clipToPadding="false"/>
        </LinearLayout>

        <!-- Single active row - swaps content based on selection -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/activeRow"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:paddingHorizontal="12dp"
            android:clipToPadding="false"/>

        <!-- Row indicators -->
        <LinearLayout
            android:id="@+id/rowIndicators"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

</FrameLayout>
