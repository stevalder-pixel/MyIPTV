<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Watchlist row (hidden if empty) -->
        <LinearLayout android:id="@+id/watchlistSection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="My Watchlist" android:textColor="#FFFFFF" android:textSize="20sp"
                android:textStyle="bold" android:paddingStart="16dp" android:paddingTop="20dp"
                android:paddingBottom="12dp" android:fontFamily="@font/netflix_sans_medium"/>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/watchlistRow"
                android:layout_width="match_parent" android:layout_height="225dp"
                android:paddingHorizontal="12dp" android:clipToPadding="false"
                android:orientation="horizontal"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Trending Movies" android:textColor="#FFFFFF" android:textSize="20sp"
            android:textStyle="bold" android:paddingStart="16dp" android:paddingTop="20dp"
            android:paddingBottom="12dp" android:fontFamily="@font/netflix_sans_medium"/>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/trendingRow"
            android:layout_width="match_parent" android:layout_height="225dp"
            android:paddingHorizontal="12dp" android:clipToPadding="false"
            android:orientation="horizontal"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Popular" android:textColor="#FFFFFF" android:textSize="20sp"
            android:textStyle="bold" android:paddingStart="16dp" android:paddingTop="20dp"
            android:paddingBottom="12dp" android:fontFamily="@font/netflix_sans_medium"/>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/popularRow"
            android:layout_width="match_parent" android:layout_height="225dp"
            android:paddingHorizontal="12dp" android:clipToPadding="false"
            android:orientation="horizontal"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Top Rated" android:textColor="#FFFFFF" android:textSize="20sp"
            android:textStyle="bold" android:paddingStart="16dp" android:paddingTop="20dp"
            android:paddingBottom="12dp" android:fontFamily="@font/netflix_sans_medium"/>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/topRatedRow"
            android:layout_width="match_parent" android:layout_height="225dp"
            android:paddingHorizontal="12dp" android:clipToPadding="false"
            android:orientation="horizontal"/>

        <ProgressBar android:id="@+id/progressBar"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_gravity="center" android:visibility="gone"
            android:indeterminateTint="#48CAE4" android:layout_marginTop="16dp"/>

        <View android:layout_width="match_parent" android:layout_height="32dp"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
