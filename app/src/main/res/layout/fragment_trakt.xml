<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">
    <Button
        android:id="@+id/traktLoginBtn"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Login with Trakt"
        android:backgroundTint="@color/accent_blue"
        android:textColor="@color/bg_primary"
        android:layout_marginBottom="16dp" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <Button android:id="@+id/watchlistTab"
            android:layout_width="0dp" android:layout_height="36dp"
            android:layout_weight="1" android:text="Watchlist"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/accent_blue" android:layout_marginEnd="8dp" />
        <Button android:id="@+id/historyTab"
            android:layout_width="0dp" android:layout_height="36dp"
            android:layout_weight="1" android:text="History"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/accent_blue" android:layout_marginEnd="8dp" />
        <Button android:id="@+id/recommendationsTab"
            android:layout_width="0dp" android:layout_height="36dp"
            android:layout_weight="1" android:text="Recommendations"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/accent_blue" />
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/traktRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>